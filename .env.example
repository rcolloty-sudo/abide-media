# Abide Media Group — environment variables

# ── Email (Resend) — used by the contact + brief forms ──
RESEND_API_KEY=
FROM_EMAIL="Abide Media <hello@abidemediagroup.com.au>"
TO_EMAIL=hello@abidemediagroup.com.au

# ── Admin portal (Supabase) ──
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated allowlist of emails permitted to sign in to /admin
ADMIN_EMAILS=hello@abidemediagroup.com.au
